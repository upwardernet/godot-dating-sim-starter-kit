{
  "meta": {
    "title": "Sigma Date - Episode 1",
    "version": "7.0",
    "language": "en"
  },
  "script": [
    {"type": "label", "label": "start"},
    {"type": "bg", "id": "living_room"},
    {"type": "show", "char": "elena", "expr": "happy"},
    {"type": "say", "char": "elena", "expr": "happy", "text": "Welcome! I'm Elena. Make yourself at home.", "say_index": 0},
    {"type": "show", "char": "maya", "expr": "happy"},
    {"type": "say", "char": "maya", "expr": "happy", "text": "Hey! I'm Maya. This place is way more fun with you here~", "say_index": 1},
    {"type": "show", "char": "vanessa", "expr": "neutral"},
    {"type": "say", "char": "vanessa", "expr": "neutral", "text": "I'm Vanessa. Elena's sister. Don't let them fool you — this house is interesting.", "say_index": 2},
    {"type": "say", "char": "", "expr": "", "text": "Three women. One house. Your semester starts now.", "say_index": 3},
    {"type": "choice", "options": [
      {"text": "Talk to Elena", "jump": "talk_elena"},
      {"text": "Talk to Maya", "jump": "talk_maya"},
      {"text": "Talk to Vanessa", "jump": "talk_vanessa"}
    ]},
    {"type": "label", "label": "talk_elena"},
    {"type": "show", "char": "elena", "expr": "happy"},
    {"type": "change_attraction", "char": "elena", "value": 1},
    {"type": "say", "char": "elena", "expr": "happy", "text": "Oh, that's sweet. Dinner will be ready soon.", "say_index": 4},
    {"type": "jump", "label": "evening"},
    {"type": "label", "label": "talk_maya"},
    {"type": "show", "char": "maya", "expr": "flirt"},
    {"type": "change_attraction", "char": "maya", "value": 1},
    {"type": "say", "char": "maya", "expr": "flirt", "text": "I knew you'd pick me! Let's have some fun~", "say_index": 5},
    {"type": "jump", "label": "evening"},
    {"type": "label", "label": "talk_vanessa"},
    {"type": "show", "char": "vanessa", "expr": "flirt"},
    {"type": "change_attraction", "char": "vanessa", "value": 1},
    {"type": "say", "char": "vanessa", "expr": "flirt", "text": "Interesting choice. I like that.", "say_index": 6},
    {"type": "jump", "label": "evening"},
    {"type": "label", "label": "evening"},
    {"type": "bg", "id": "kitchen"},
    {"type": "hide", "char": "maya"},
    {"type": "hide", "char": "elena"},
    {"type": "hide", "char": "vanessa"},
    {"type": "say", "char": "", "expr": "", "text": "Evening falls. The house grows quiet.", "say_index": 7},
    {"type": "show", "char": "elena", "expr": "neutral"},
    {"type": "say", "char": "elena", "expr": "neutral", "text": "Your first day went well. Rest up — tomorrow is a new start.", "say_index": 8},
    {"type": "choice", "options": [
      {"text": "Spend time with Elena", "jump": "night_elena"},
      {"text": "Chat with Maya", "jump": "night_maya"},
      {"text": "Talk with Vanessa", "jump": "night_vanessa"}
    ]},
    {"type": "label", "label": "night_elena"},
    {"type": "show", "char": "elena", "expr": "happy"},
    {"type": "change_attraction", "char": "elena", "value": 1},
    {"type": "say", "char": "elena", "expr": "happy", "text": "Thank you for staying. It's nice to have someone to talk to.", "say_index": 9},
    {"type": "jump", "label": "finale"},
    {"type": "label", "label": "night_maya"},
    {"type": "show", "char": "maya", "expr": "happy"},
    {"type": "change_attraction", "char": "maya", "value": 1},
    {"type": "say", "char": "maya", "expr": "happy", "text": "Movie night! Don't worry, I'll pick something good.", "say_index": 10},
    {"type": "jump", "label": "finale"},
    {"type": "label", "label": "night_vanessa"},
    {"type": "show", "char": "vanessa", "expr": "flirt"},
    {"type": "change_attraction", "char": "vanessa", "value": 1},
    {"type": "say", "char": "vanessa", "expr": "flirt", "text": "The stars are beautiful tonight. Glad you're here to see them.", "say_index": 11},
    {"type": "jump", "label": "finale"},
    {"type": "label", "label": "finale"},
    {"type": "bg", "id": "living_room"},
    {"type": "hide", "char": "maya"},
    {"type": "hide", "char": "elena"},
    {"type": "hide", "char": "vanessa"},
    {"type": "say", "char": "", "expr": "", "text": "Your first days are over. The story continues...", "say_index": 12},
    {"type": "wait", "duration": 0.5},
    {"type": "say", "char": "", "expr": "", "text": "— To be continued —", "say_index": 13},
    {"type": "label", "label": "end"}
  ]
}
